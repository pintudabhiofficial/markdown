    {
      "@type": "FAQPage",
      "@id": "https://markdownpreviewlive.com/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Can I use HTML inside a .md file?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, inline HTML is fully supported in Markdown files. You can write standard HTML tags directly within your .md content. Block-level HTML elements such as div, table, and details require blank-line separation from surrounding Markdown content to render correctly."
          }
        },
        {
          "@type": "Question",
          "name": "Which Markdown specification should I follow?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "CommonMark for maximum portability across platforms and tools. If you publish primarily on GitHub, GitHub Flavored Markdown (GFM) covers everything you need — it is a strict CommonMark superset that adds tables, strikethrough, autolinks, and task lists."
          }
        },
        {
          "@type": "Question",
          "name": "What is the best Markdown editor for someone starting out?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "A browser-based Markdown editor provides immediate, zero-install feedback and is ideal for beginners. For desktop use, Mark Text offers a clean learning experience with real-time rendering, open-source availability, and support for both CommonMark and GFM specifications."
          }
        },
        {
          "@type": "Question",
          "name": "How do I produce a PDF from a Markdown file?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pandoc is the gold standard for professional-grade Markdown to PDF conversion, producing typeset-quality output through LaTeX. VS Code extensions work well for quick one-off exports, and Typora offers a GUI-based workflow for users who prefer a visual interface."
          }
        },
        {
          "@type": "Question",
          "name": "Is CommonMark the same as the original Markdown?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "CommonMark is a strict, unambiguous formalisation of John Gruber's original informal specification. It resolves edge cases and ambiguities that the 2004 spec left undefined, ensuring consistent rendering across all compliant parsers and platforms."
          }
        },
        {
          "@type": "Question",
          "name": "Why do AI models output Markdown format?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Token efficiency is the primary reason. A Markdown heading costs 3-4 tokens compared to 7-8 tokens for the equivalent HTML. The format also preserves semantic structure — headings, lists, emphasis — in a way that is immediately useful to both human readers and downstream processing systems."
          }
        }
      ]
    }
